# Copy this file to .env and adjust values for your setup.

# Host port mappings (chosen to avoid clashing with the DigiByte stack)
HOST_BCH_P2P_PORT=18333
HOST_BCH_RPC_PORT=18332
HOST_STRATUM_PORT=4333
HOST_CKPOOL_API_PORT=14028
HOST_LOGS_HTTP_PORT=13001
HOST_CKSTATS_PORT=13000
HOST_DB_PORT=15432

# Node mode
TESTNET=0
WAIT_FOR_FULL_SYNC=0
PRUNE=550

# Bitcoin Cash Node RPC
RPCUSER=rpcuser
RPCPASSWORD=rpcpassword
RPCPORT=8332
RPCBIND=0.0.0.0
RPCALLOWIP=0.0.0.0/0

# BCH daemon networking
PORT=8333
ONLYNET=IPv4
ZMQPUBHASHBLOCK=tcp://127.0.0.1:28333
DATADIR=/home/bitcoin/.bitcoin

# ckpool values
BTCD_URL=127.0.0.1:8332
BTCD_AUTH=rpcuser
BTCD_PASS=rpcpassword
SERVERURL=0.0.0.0:3333
BTCADDRESS=replace_with_bch_address
BTCSIG=/mined by me/
MINDIFF=250000
STARTDIFF=250000
ZMQBLOCK=tcp://127.0.0.1:28333

# PostgreSQL
POSTGRES_USER=ckstats
POSTGRES_PASSWORD=ckstats
POSTGRES_DB=ckstats

# ckstats
DATABASE_URL=postgres://ckstats:ckstats@db/ckstats
SHADOW_DATABASE_URL=postgres://ckstats:ckstats@db/dbshadow
API_URL=http://bitcoincash-ckpool
